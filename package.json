{
  "name": "okta-terraform-toolkit",
  "version": "0.1.0",
  "description": "Rate limit optimizer for the Okta Terraform provider",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run build:main -- --watch\" \"npm run build:preload -- --watch\" \"npm run build:renderer -- --watch\" \"wait-on dist/main/index.js dist/renderer/index.html && electron .\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js",
    "build:preload": "webpack --config webpack.preload.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.7.0",
    "jsonwebtoken": "^9.0.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.0.0",
    "electron": "^33.0.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0",
    "webpack": "^5.96.0",
    "webpack-cli": "^5.1.0"
  }
}
